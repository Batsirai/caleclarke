# Copy to .env and set. For Astro, only vars prefixed with PUBLIC_ are exposed to the client.

# Contact forms → /api/contact (Cloudflare Pages Function → Static Forms).
# In Cloudflare Pages: Settings → Environment variables:
#   STATICFORMS_API_KEY = (secret) your key from https://www.staticforms.dev (dashboard)
# Local testing: put STATICFORMS_API_KEY in .dev.vars at repo root, then npm run dev:pages
# PUBLIC_CONTACT_API_URL=/api/contact

# Kit — defaults match Cale’s form (6699201 / ea19c66b27); override if the form changes.
PUBLIC_KIT_FORM_UID=ea19c66b27
PUBLIC_KIT_FORM_ID=6699201
# PUBLIC_KIT_FORM_ACTION=https://app.kit.com/forms/6699201/subscriptions

# Optional: full script URL if Kit serves something other than f.convertkit.com/{uid}/index.js
# PUBLIC_KIT_EMBED_SCRIPT_SRC=

# form (default) = plain HTML POST to Kit — form always visible | script = ConvertKit JS embed
# PUBLIC_KIT_EMBED_MODE=script

# Optional: override The Faith Explained / Institute link (default: thefaithexplained.com)
# PUBLIC_FEI_WEBSITE_URL=https://www.example.com/

# Optional: donate page (default: thefaithexplained.com/donate)
# PUBLIC_FEI_DONATE_URL=

# Optional: override LinkedIn profile URL (default: cale-clarke-4636a12b)
# PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/...

# The Cale Clarke Show — listen links (Apple defaults to known show id; set others when ready)
# PUBLIC_PODCAST_APPLE_URL=
# PUBLIC_PODCAST_SPOTIFY_URL=
# PUBLIC_PODCAST_YOUTUBE_URL=
# Optional: podcast cover image path (default: /images/podcast-cale-clarke-show-cover.webp)
# PUBLIC_PODCAST_COVER_SRC=
