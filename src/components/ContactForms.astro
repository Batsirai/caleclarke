---
/**
 * Contact forms POST to /api/contact (Cloudflare Pages Function → Static Forms).
 * Set STATICFORMS_API_KEY (secret) in Cloudflare Pages. Optional: PUBLIC_CONTACT_API_URL.
 */
const contactApiPath = import.meta.env.PUBLIC_CONTACT_API_URL ?? "/api/contact";
---

<section id="contact" class="contact-root" aria-labelledby="contact-heading">
  <div class="contact-inner">
    <h2 id="contact-heading" class="contact-title">Book a talk or send a note</h2>
    <p class="contact-lead">
      Speaking requests use the first form. Pilgrimages, podcast ideas, media, or anything else — use the second. I read both and reply myself.
    </p>

    <p
      class="contact-thanks contact-thanks--book"
      id="contact-thanks-book"
      role="status"
      aria-live="polite"
      hidden
    >
      Thank you — I received your booking inquiry and I’ll get back to you soon.
    </p>
    <p
      class="contact-thanks contact-thanks--contact"
      id="contact-thanks-contact"
      role="status"
      aria-live="polite"
      hidden
    >
      Thank you — I received your message.
    </p>

    <div class="contact-grid">
      <div id="book" class="contact-card">
        <h3 class="contact-card-title">Speaking inquiry</h3>
        <p class="contact-card-desc">Keynotes, Saturday seminars, parish missions, deanery weekends — share your date, place, and who will be in the room.</p>
        <form class="contact-form" data-contact-form="book" name="book-cale">
          <input type="text" name="_trap" class="contact-honey" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <p class="contact-form-error" role="alert" hidden></p>

          <label class="contact-field">
            <span class="contact-label">Name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label class="contact-field">
            <span class="contact-label">Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label class="contact-field">
            <span class="contact-label">Organization / parish (optional)</span>
            <input type="text" name="organization" autocomplete="organization" />
          </label>
          <label class="contact-field">
            <span class="contact-label">Event date or window</span>
            <input type="text" name="event_date" placeholder="e.g. Fall 2025 or March 15" />
          </label>
          <label class="contact-field">
            <span class="contact-label">City &amp; region</span>
            <input type="text" name="location" />
          </label>
          <label class="contact-field contact-field--full">
            <span class="contact-label">Audience &amp; format</span>
            <textarea name="audience_and_format" rows="3" placeholder="Who will be there, in person or virtual, approximate size…"></textarea>
          </label>
          <label class="contact-field contact-field--full">
            <span class="contact-label">Anything else I should know</span>
            <textarea name="message" rows="4"></textarea>
          </label>

          <button type="submit" class="contact-submit">Send speaking inquiry</button>
          <p class="contact-form-success" role="status" aria-live="polite" hidden tabindex="-1">
            Thank you — I received your booking inquiry and I’ll get back to you soon.
          </p>
        </form>
      </div>

      <div class="contact-card">
        <h3 class="contact-card-title">Everything else</h3>
        <p class="contact-card-desc">
          Pilgrimages, podcast guests or topics, introductions, press — not a speaking date? Use this form.
        </p>
        <form class="contact-form" data-contact-form="general" name="general-contact">
          <input type="text" name="_trap" class="contact-honey" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <p class="contact-form-error" role="alert" hidden></p>

          <label class="contact-field">
            <span class="contact-label">Name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label class="contact-field">
            <span class="contact-label">Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label class="contact-field contact-field--full">
            <span class="contact-label">Message</span>
            <textarea name="message" rows="6" required></textarea>
          </label>

          <button type="submit" class="contact-submit">Send message</button>
          <p class="contact-form-success" role="status" aria-live="polite" hidden tabindex="-1">
            Thank you — I received your message.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ contactApiPath }}>
  (function () {
    function showThanks(kind) {
      var id = kind === "book" ? "contact-thanks-book" : "contact-thanks-contact";
      var el = document.getElementById(id);
      if (el) {
        el.hidden = false;
        el.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    }

    function hideThanks() {
      ["contact-thanks-book", "contact-thanks-contact"].forEach(function (hid) {
        var el = document.getElementById(hid);
        if (el) el.hidden = true;
      });
    }

    try {
      var q = new URLSearchParams(window.location.search);
      if (q.get("sent") === "book") showThanks("book");
      if (q.get("sent") === "contact") showThanks("general");
    } catch (_) {}

    document.querySelectorAll("[data-contact-form]").forEach(function (form) {
      var errEl = form.querySelector(".contact-form-error");
      var successEl = form.querySelector(".contact-form-success");
      var submitBtn = form.querySelector('button[type="submit"]');
      var defaultLabel = submitBtn ? submitBtn.textContent.trim() : "";

      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        if (errEl) {
          errEl.hidden = true;
          errEl.textContent = "";
        }
        if (successEl) {
          successEl.hidden = true;
        }

        var fd = new FormData(form);
        if ((fd.get("_trap") || "").toString().trim()) return;

        var formKind = form.getAttribute("data-contact-form");
        if (formKind !== "book" && formKind !== "general") return;

        var payload = {
          form: formKind === "book" ? "book" : "general",
          name: fd.get("name"),
          email: fd.get("email"),
          message: fd.get("message") || "",
          _trap: "",
        };

        if (formKind === "book") {
          payload.organization = fd.get("organization") || "";
          payload.event_date = fd.get("event_date") || "";
          payload.location = fd.get("location") || "";
          payload.audience_and_format = fd.get("audience_and_format") || "";
        }

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Sending…";
        }
        hideThanks();

        try {
          var res = await fetch(contactApiPath, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          var data = await res.json().catch(function () {
            return {};
          });
          var succeeded = res.ok && data && data.ok === true;
          if (succeeded) {
            form.reset();
            hideThanks();
            if (successEl) {
              successEl.hidden = false;
              successEl.scrollIntoView({ behavior: "smooth", block: "center" });
              try {
                successEl.focus();
              } catch (_) {}
            } else {
              showThanks(formKind === "book" ? "book" : "general");
            }
          } else {
            var msg =
              res.status === 503
                ? "This form is not configured yet. Please try again later."
                : res.status === 429
                  ? "The form service is rate-limited right now (Static Forms allows a limited number of emails per minute and per month). Wait a few minutes and try again, or check your Static Forms dashboard for quota."
                  : "Something went wrong. Please try again or email directly.";
            if (res.status === 429 && data && data.detail) {
              msg += " " + String(data.detail);
            }
            if (errEl) {
              errEl.textContent = msg;
              errEl.hidden = false;
              errEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
            } else {
              window.alert(msg);
            }
          }
        } catch (_) {
          var netMsg = "Network error. Check your connection and try again.";
          if (errEl) {
            errEl.textContent = netMsg;
            errEl.hidden = false;
            errEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
          } else {
            window.alert(netMsg);
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = defaultLabel;
          }
        }
      });
    });
  })();
</script>

<style>
  .contact-root {
    scroll-margin-top: 80px;
    padding: var(--space-xl) var(--space-md);
    background: linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-bg-2) 40%, var(--color-bg)) 100%);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .contact-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.85rem, 3.5vw, 2.35rem);
    line-height: 1.15;
    margin: 0 0 var(--space-sm);
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }

  .contact-lead {
    margin: 0 0 var(--space-lg);
    max-width: 42rem;
    color: var(--color-ink-muted);
    font-size: 1.0625rem;
    line-height: 1.65;
  }

  .contact-thanks {
    margin: 0 0 var(--space-md);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-bg-elevated));
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
    color: var(--color-ink);
    font-size: 0.975rem;
  }

  .contact-form-error,
  .contact-form-success {
    grid-column: 1 / -1;
    margin: 0;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .contact-form-error {
    margin-bottom: 0;
    background: color-mix(in srgb, #b42318 10%, var(--color-bg-elevated));
    border: 1px solid color-mix(in srgb, #b42318 28%, var(--color-border));
    color: var(--color-ink);
  }

  .contact-form-success {
    margin-top: var(--space-xs);
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-bg-elevated));
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
    color: var(--color-ink);
  }

  .contact-form-success:focus {
    outline: none;
  }

  .contact-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
  }

  .contact-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-soft);
  }

  .contact-card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.45rem;
    margin: 0 0 var(--space-xs);
    color: var(--color-ink);
  }

  .contact-card-desc {
    margin: 0 0 var(--space-md);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    line-height: 1.55;
  }

  .contact-form {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 480px) {
    .contact-form {
      grid-template-columns: 1fr 1fr;
    }

    .contact-field--full {
      grid-column: 1 / -1;
    }
  }

  .contact-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .contact-label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-ink-muted);
  }

  .contact-field input,
  .contact-field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: #fff;
    color: var(--color-ink);
    width: 100%;
    box-sizing: border-box;
  }

  .contact-field textarea {
    resize: vertical;
    min-height: 5rem;
    line-height: 1.5;
  }

  .contact-field input:focus-visible,
  .contact-field textarea:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .contact-honey {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contact-submit {
    grid-column: 1 / -1;
    justify-self: start;
    margin-top: 0.25rem;
    min-height: 48px;
    padding: 0.85rem 1.35rem;
    background: var(--color-accent);
    color: #f8f6f1;
    border: none;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.15s ease;
  }

  .contact-submit:hover {
    background: var(--color-accent-hover);
    box-shadow: var(--shadow-lift);
  }

  .contact-submit:active {
    transform: translateY(1px);
  }

  .contact-submit:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .contact-submit:disabled {
    opacity: 0.75;
    cursor: not-allowed;
    transform: none;
  }
</style>
