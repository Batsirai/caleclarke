---
const nav = [
  { href: "#newsletter", label: "Newsletter" },
  { href: "#podcast", label: "Podcast" },
  { href: "#speaking", label: "Speaking" },
  { href: "#pilgrimages", label: "Pilgrimages" },
  { href: "#institute", label: "Institute" },
  { href: "#about", label: "About" },
  { href: "#contact", label: "Contact" },
];
---

<header class="site-header" data-site-header>
  <div class="site-header-inner">
    <a class="site-logo" href="#top">Cale Clarke</a>
    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open menu"
    >
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>
    <nav id="primary-nav" class="site-nav" aria-label="Primary">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.querySelector(".nav-toggle");
    var nav = document.getElementById("primary-nav");
    if (!btn || !nav) return;

    function close() {
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Open menu");
      nav.classList.remove("site-nav--open");
    }

    btn.addEventListener("click", function () {
      var open = btn.getAttribute("aria-expanded") === "true";
      if (open) {
        close();
      } else {
        btn.setAttribute("aria-expanded", "true");
        btn.setAttribute("aria-label", "Close menu");
        nav.classList.add("site-nav--open");
      }
    });

    nav.querySelectorAll("a").forEach(function (link) {
      link.addEventListener("click", close);
    });
  })();
</script>

<style>
  /* Over hero: light text on photo; no cream bar */
  .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    width: 100%;
    background: transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .site-header-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1rem var(--space-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: nowrap;
  }

  .site-logo {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    color: #fff;
    text-decoration: none;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .site-logo:hover {
    color: #fff;
    opacity: 0.92;
  }

  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-sm);
    align-items: center;
  }

  .site-nav a {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    padding: 0.5rem 0.35rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius);
    transition:
      color 0.18s ease,
      opacity 0.18s ease;
  }

  .site-nav a:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-logo:focus-visible,
  .site-nav a:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.95);
    outline-offset: 3px;
  }

  /* After scrolling past hero: fixed bar, dark text (must beat hero styles) */
  .site-header.site-header--past-hero {
    position: fixed !important;
    background: color-mix(in srgb, var(--color-bg) 98%, #fff) !important;
    border-bottom: 1px solid var(--color-border) !important;
    box-shadow: 0 4px 24px rgba(26, 23, 20, 0.08);
  }

  .site-header.site-header--past-hero .site-logo {
    color: var(--color-ink) !important;
    text-shadow: none;
  }

  .site-header.site-header--past-hero .site-logo:hover {
    color: var(--color-accent) !important;
    opacity: 1;
  }

  .site-header.site-header--past-hero .site-nav a {
    color: var(--color-ink-muted) !important;
    text-shadow: none;
  }

  .site-header.site-header--past-hero .site-nav a:hover {
    color: var(--color-ink) !important;
  }

  .site-header.site-header--past-hero .site-logo:focus-visible,
  .site-header.site-header--past-hero .site-nav a:focus-visible {
    outline-color: var(--color-accent) !important;
  }

  /* --- Hamburger toggle (mobile only) --- */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 60;
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.95);
    outline-offset: 3px;
  }

  /* Past-hero: dark bars */
  .site-header.site-header--past-hero .nav-toggle-bar {
    background: var(--color-ink) !important;
  }

  @media (max-width: 720px) {
    .nav-toggle {
      display: flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: color-mix(in srgb, var(--color-bg) 98%, #fff);
      border-bottom: 1px solid var(--color-border);
      box-shadow: 0 8px 32px rgba(26, 23, 20, 0.12);
      padding: var(--space-sm) var(--space-md) var(--space-md);
    }

    .site-nav--open {
      display: block;
    }

    .site-nav ul {
      flex-direction: column;
      gap: 0;
    }

    .site-nav a {
      color: var(--color-ink) !important;
      text-shadow: none !important;
      padding: 0.75rem 0.5rem;
      min-height: 48px;
      border-bottom: 1px solid var(--color-border);
      width: 100%;
      display: flex;
    }

    .site-nav li:last-child a {
      border-bottom: none;
    }

    .site-nav a:hover {
      color: var(--color-accent) !important;
      background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    }
  }
</style>
